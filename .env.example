# -----------------------------------------------------------------------------
# L'ARTISAN PATISSERIE - ENVIRONMENT VARIABLES
# Rename this file to `.env` and fill in your actual credentials.
# -----------------------------------------------------------------------------

# DATABASE
# Required for Prisma ORM (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# EMAIL NOTIFICATIONS (NODEMAILER)
# Use a Gmail App Password. Do NOT use your real Gmail password.
# 1. Go to Google Account -> Security -> 2-Step Verification
# 2. At the bottom, click "App passwords" -> Generate one.
EMAIL_USER="your-bakery-email@gmail.com"
EMAIL_PASS="your-16-character-app-password"

# SMS NOTIFICATIONS (TWILIO)
# Create a free account at twilio.com to get these.
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
